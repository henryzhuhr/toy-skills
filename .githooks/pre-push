#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

if ! command -v uv >/dev/null 2>&1; then
    echo "[pre-push] uv 未安装，无法执行 pytest。"
    echo "[pre-push] 请先安装 uv，或手动执行: uv run --group dev pytest -q tests"
    exit 1
fi

echo "[pre-push] 运行测试: uv run --group dev pytest -q tests"
uv run --group dev pytest -q tests
echo "[pre-push] 测试通过。"
